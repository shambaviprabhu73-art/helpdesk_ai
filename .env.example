# HelpDesk AI — Environment Configuration
#
# Copy this file to .env and fill in your Supabase credentials.
# You can find these in your Supabase Dashboard → Project Settings → API

# Supabase Configuration (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: The following are used server-side only (edge functions, migrations).
# They are pre-populated in the hosted environment and should NEVER be
# committed to version control or exposed in the frontend.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DB_URL=your-database-url
